{
    "version": 1,
    "canisters": {
      "backend": {
        "type": "motoko",
        "main": "backend/main.mo",
        "declarations": {
          "bindings": ["ts", "did"],
          "output": "frontend/src/declarations/backend"
        },
        "dependencies": []
      },
      "frontend": {
        "type": "assets",
        "source": ["frontend/dist"],
        "dependencies": ["backend"],
        "build": [
          "cd frontend && npm install && npm run build"
        ]
      }
    },
    "defaults": {
      "build": {
        "packtool": "",
        "args": ""
      }
    },
    "output_env_file": ".env",
    "networks": {
      "local": {
        "bind": "127.0.0.1:4943",
        "type": "plain"
      }
    }
  }